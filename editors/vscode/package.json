{
  "name": "agitrack-vscode",
  "displayName": "aGiTrack",
  "description": "Launch aGiTrack — a coding agent (Claude Code / OpenCode) that auto-commits every turn with full provenance — inside VSCode, with no terminal typing required.",
  "version": "0.0.9",
  "publisher": "core-aix",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "homepage": "https://github.com/core-aix/agitrack",
  "repository": {
    "type": "git",
    "url": "https://github.com/core-aix/agitrack"
  },
  "bugs": {
    "url": "https://github.com/core-aix/agitrack/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "opencode",
    "git",
    "commit"
  ],
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "SCM Providers",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0d6e63",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agitrack.start",
        "title": "Start Session",
        "category": "aGiTrack",
        "icon": "$(git-commit)"
      },
      {
        "command": "agitrack.startHere",
        "title": "Start Session Here",
        "category": "aGiTrack"
      },
      {
        "command": "agitrack.restart",
        "title": "Restart Session",
        "category": "aGiTrack"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "agitrack.startHere",
          "group": "navigation@99",
          "when": "explorerResourceIsFolder"
        }
      ],
      "commandPalette": [
        {
          "command": "agitrack.startHere",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "aGiTrack",
      "properties": {
        "agitrack.path": {
          "type": "string",
          "default": "agitrack",
          "description": "Path to the agitrack executable (on PATH by default)."
        },
        "agitrack.backend": {
          "type": "string",
          "default": "",
          "enum": ["", "claude", "opencode"],
          "enumDescriptions": [
            "Use aGiTrack's configured default backend",
            "Claude Code",
            "OpenCode"
          ],
          "description": "Backend to drive. Empty uses aGiTrack's configured default."
        },
        "agitrack.args": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Extra command-line arguments passed to aGiTrack (e.g. [\"--no-worktree\"])."
        },
        "agitrack.openOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start an aGiTrack session when a workspace opens."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
