<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v5 source for the aGiTrack Windows installer (schema namespace is still
  .../v4/wxs — WiX v5 kept the v4 schema).

  Build (after running PyInstaller into dist/agitrack):
    wix build installer/agitrack.wxs               \
         -d Version=<x.y.z>                        \
         -d SourceDir=<abs path>/dist/agitrack     \
         -ext WixToolset.UI.wixext                 \
         -o dist/agitrack-<x.y.z>-windows-x64.msi

  Requires WiX v5: the <Files Include="$(var.SourceDir)\**"> element (in the
  AgitrackFiles ComponentGroup below) globs and harvests the PyInstaller output
  directory at build time — it replaces the removed `heat`/`wix harvest` step and was
  only added in WiX v5. Pass SourceDir as an ABSOLUTE path so the glob is unambiguous,
  and pin the WixToolset.UI.wixext extension to the SAME version as the wix tool.

  UpgradeCode must NEVER change between releases — it is the stable identity
  Windows uses to recognise that two MSI packages are versions of the same
  product and to offer upgrade/replace rather than side-by-side install.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="aGiTrack"
    Manufacturer="core-aix"
    Version="$(var.Version)"
    UpgradeCode="BC494705-7419-478F-BE35-9BA5F9E5B054"
    Scope="perMachine"
    Compressed="yes"
    InstallerVersion="500">

    <!--
      Remove any older version before installing the new one.
      MajorUpgrade handles the "newer version already installed" guard too.
    -->
    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of aGiTrack is already installed. Uninstall it first." />

    <MediaTemplate EmbedCab="yes" />

    <!-- ================================================================ -->
    <!-- Directory layout                                                    -->
    <!-- ================================================================ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="aGiTrack" />
    </StandardDirectory>

    <!-- Start Menu shortcut lives under the current user's programs folder  -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="aGiTrack" />
    </StandardDirectory>

    <!-- ================================================================ -->
    <!-- Components                                                          -->
    <!-- ================================================================ -->

    <!--
      Add the install folder to the system PATH so users can type "agitrack"
      from any terminal without an absolute path.  The environment variable
      change is broadcast to running processes after installation.
    -->
    <ComponentGroup Id="PathComponents" Directory="INSTALLFOLDER">
      <Component Id="AddToPath" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <Environment
          Id="PATH"
          Name="PATH"
          Value="[INSTALLFOLDER]"
          Action="set"
          Part="last"
          Permanent="no"
          System="yes" />
        <!-- Dummy registry key so Windows can track this component -->
        <RegistryValue
          Root="HKLM"
          Key="Software\aGiTrack"
          Name="InstallDir"
          Value="[INSTALLFOLDER]"
          Type="string"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Start Menu shortcut -->
    <ComponentGroup Id="ShortcutComponents" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <Shortcut
          Id="AgitrackShortcut"
          Name="aGiTrack"
          Description="AI coding agent with git integration"
          Target="[INSTALLFOLDER]agitrack.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanUpShortcutFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\aGiTrack"
          Name="StartMenuShortcut"
          Value="1"
          Type="integer"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!--
      The PyInstaller bundle (agitrack.exe + the _internal/ tree). The WiX v5 <Files>
      element globs and harvests the whole directory at build time, recreating the
      subdirectory structure under INSTALLFOLDER and generating a component per file —
      it replaces the removed heat/`wix harvest` step. var.SourceDir is passed (as an
      absolute path) on the `wix build` command line, so this stays in lockstep with
      the PyInstaller output directory.
    -->
    <ComponentGroup Id="AgitrackFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.SourceDir)\**" />
    </ComponentGroup>

    <!--
      The MSI self-update bootstrapper. It is committed in the repo (not part of the
      PyInstaller output), so install it explicitly from this .wxs's own directory
      ($(sys.SOURCEFILEDIR)). It lands next to agitrack.exe in INSTALLFOLDER and is
      updated by the same MSI that updates the rest of the install. See
      agitrack/proxy/runner.py:_launch_msi_bootstrapper and docs/design/msi-self-update.md.
    -->
    <ComponentGroup Id="UpdaterComponents" Directory="INSTALLFOLDER">
      <Component Id="UpdaterBootstrapper" Guid="C7F0A2E1-9D3B-4A6C-8E25-3F1B0D9A4C77">
        <File Id="AgitrackUpdateCmd" Source="$(sys.SOURCEFILEDIR)agitrack-update.cmd" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ================================================================ -->
    <!-- Feature tree                                                        -->
    <!-- ================================================================ -->
    <Feature Id="Main" Title="aGiTrack" Level="1">
      <!-- All harvested PyInstaller output files -->
      <ComponentGroupRef Id="AgitrackFiles" />
      <!-- MSI self-update bootstrapper -->
      <ComponentGroupRef Id="UpdaterComponents" />
      <!-- PATH entry -->
      <ComponentGroupRef Id="PathComponents" />
      <!-- Start Menu shortcut -->
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>

    <!-- ================================================================ -->
    <!-- UI                                                                  -->
    <!-- ================================================================ -->
    <!--
      WixUI_Minimal: just a license agreement page + install/cancel.
      Swap for WixUI_InstallDir if you want a folder-picker page.
    -->
    <ui:WixUI Id="WixUI_Minimal" />

    <!--
      Show aGiTrack's actual licence (Apache-2.0) on the EULA page. Without this WiX shows
      its built-in placeholder text. installer/license.rtf is generated from the repo's
      LICENSE file; $(sys.SOURCEFILEDIR) is the directory of this .wxs, so the path resolves
      no matter what working directory `wix build` runs from.
    -->
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)license.rtf" />

  </Package>
</Wix>
